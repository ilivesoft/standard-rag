config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	retrieve(retrieve)
	rerank(rerank)
	generate(generate)
	no_docs(no_docs)
	__end__([<p>__end__</p>]):::last
